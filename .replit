entrypoint = "README.md"
modules = ["nodejs-22", "javascript", "node", "postgresql-16"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5904
externalPort = 3000

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["expo_object_storage:1.0.0", "revenuecat:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push OTA Update"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run expo:dev"

[[workflows.workflow]]
name = "Push OTA Update"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "CI=1 EXPO_TOKEN=$EXPO_TOKEN npx eas update --channel production --message \"v1.3.0\""

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[userenv]

[userenv.shared]
REVENUECAT_PROJECT_ID = "proj935794a2"
REVENUECAT_TEST_STORE_APP_ID = "appe6c7c06d44"
REVENUECAT_APPLE_APP_STORE_APP_ID = "app5d61d2ce76"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "app6563780fe2"
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_PCtqhMKgDGQaDZBiiHJOwIJyxJY"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_gLyffjGmkpTPFLvNELDEAZHprrq"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_ozniPPLOKQmBqzhHNwGcdYMpvDj"
SMTP_USER = "support@paceupapp.com"
