# === Required ===

# Postgres connection string
DATABASE_URL=

# Session signing secret (long random string)
SESSION_SECRET=

# Public-facing app URL (used in email links, CORS)
APP_URL=https://paceupapp.com

# Comma-separated extra CORS origins (optional)
ALLOWED_ORIGINS=

# Server port (Railway injects this automatically)
PORT=5000

NODE_ENV=production

# === Cloudflare R2 (object storage for user photos) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=paceup-photos
R2_PUBLIC_URL=https://photos.paceupapp.com

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@paceupapp.com
SMTP_PASS=
SMTP_FROM="PaceUp <support@paceupapp.com>"

# === RevenueCat ===
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=

# === Other integrations ===
OPENAI_API_KEY=
GIPHY_API_KEY=

# === Optional / not yet configured ===
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
